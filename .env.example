# Ollama server URL
#   Local:  http://localhost:11434
#   Cloud:  https://ollama.com
OLLAMA_BASE_URL=http://localhost:11434

# Ollama Cloud API key (only needed when OLLAMA_BASE_URL points at https://ollama.com).
# Get one at https://ollama.com/settings/keys. Leave blank for local Ollama.
OLLAMA_API_KEY=

# Model names
#   Local examples:  qwen3.5:35b / qwen3-coder:30b / devstral-small-2
#   Cloud examples:  use the names returned by `GET <base>/api/tags` for your account
PLANNER_MODEL=qwen3.5:35b
CODER_MODEL=qwen3-coder:30b
EDITOR_MODEL=devstral-small-2

# Ralph loop settings
MAX_ITERATIONS=5
MAX_REACT_STEPS=20
REVIEWER_MAX_STEPS=8

# Research-enabled planning (PRD generation step budget)
PLANNER_MAX_STEPS=15

# Web-search planning: true (default) or false for a fast single-shot PRD.
# Overridden per-run by the --no-research CLI flag.
RESEARCH_PLANNING=true

# Web search
BRAVE_API_KEY=

# Logging
LOG_LEVEL=info
LOG_FILE=.oda.log
