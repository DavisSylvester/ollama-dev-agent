# Ollama server URL (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Model names (defaults shown)
PLANNER_MODEL=qwen3.5:35b
CODER_MODEL=qwen3-coder:30b
EDITOR_MODEL=devstral-small-2

# Ralph loop settings
MAX_ITERATIONS=5
MAX_REACT_STEPS=20
REVIEWER_MAX_STEPS=8

# Research-enabled planning (PRD generation step budget)
PLANNER_MAX_STEPS=15

# Web search
BRAVE_API_KEY=

# Logging
LOG_LEVEL=info
LOG_FILE=.oda.log
