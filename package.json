{
  "name": "ollama-dev-agent",
  "version": "0.1.0",
  "description": "A local autonomous coding agent powered by Ollama models with Ralph loop self-healing",
  "module": "src/index.mts",
  "type": "module",
  "private": true,
  "bin": {
    "oda": "./src/index.mts"
  },
  "scripts": {
    "dev": "bun --watch src/index.mts",
    "start": "bun src/index.mts",
    "test": "bun test",
    "test:unit": "bun test tests/unit",
    "test:coverage": "bun test --coverage tests/unit",
    "test:integration": "bun test tests/integration",
    "lint": "eslint 'src/**/*.{mts,tsx}'",
    "lint:fix": "eslint 'src/**/*.{mts,tsx}' --fix",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@langchain/core": "^0.3.27",
    "@langchain/langgraph": "^0.2.36",
    "@langchain/ollama": "^0.1.5",
    "axios": "^1.7.9",
    "commander": "^12.1.0",
    "dotenv": "^17.4.2",
    "execa": "^9.5.2",
    "glob": "^11.0.1",
    "ink": "^5.1.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "luxon": "^3.7.2",
    "react": "^18.3.1",
    "sqlite3": "^6.0.1",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "@types/luxon": "^3.7.1",
    "@types/react": "^19.2.17",
    "eslint": "^9.17.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.19.1"
  }
}
